# FinScreener Pro Backend - Environment Variables
# Copy this file to .env and fill in your values

# ============ REQUIRED ============

# Supabase (Database)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
# or
SUPABASE_ANON_KEY=your-anon-key

# ============ APIs ============

# Polygon.io (Real-time stock data - PAID TIER)
# Your API key: iO7G4s0BzGHxip4_W8Bou00ml0F1SRFP
POLYGON_API_KEY=iO7G4s0BzGHxip4_W8Bou00ml0F1SRFP

# Finviz Elite API
# Your API key: aee3eced-f1e8-4f3a-bd20-feabc58c111a
FINVIZ_API_KEY=aee3eced-f1e8-4f3a-bd20-feabc58c111a

# Telegram (Notifications)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id

# ============ OPTIONAL ============

# News APIs (free tiers)
# Finnhub: https://finnhub.io - Free tier: 60 req/min
FINNHUB_API_KEY=your-finnhub-key

# Alpha Vantage: https://www.alphavantage.co - Free tier: 25 req/day
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-key

# ============ SETTINGS ============

# Alert monitoring interval (milliseconds)
ALERT_CHECK_INTERVAL=30000

# Default risk per trade (%)
DEFAULT_RISK_PERCENT=1.0

# Max position size (%)
MAX_POSITION_SIZE=10

# Trailing stop multiplier (ATR)
TRAILING_STOP_MULTIPLIER=2.0

# Log level
LOG_LEVEL=info
